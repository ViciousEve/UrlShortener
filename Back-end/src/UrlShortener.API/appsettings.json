{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YourDbConnectionString"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_VERY_STRONG_SECRET_KEY_HERE_CHANGE_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "UrlShortener",
    "Audience": "UrlShortenerClient",
    "ExpirationMinutes": 1
  }
}